{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":rebaseStalePrs"
  ],
  "argocd": {
    "fileMatch": [
      "(^|/)apps/.+\\.yaml$"
    ]
  },
  "packageRules": [
    {
      "matchManagers": ["terraform"],
      "groupName": "Terraform Updates"
    },
    {
      "matchManagers": ["argocd"],
      "groupName": "ArgoCD Updates"
    }
  ]
}
