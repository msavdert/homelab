# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Allow .tfvars.example files
!*.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore tfplan files
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore sensitive generated configurations (Talos/Kubernetes)
**/kubeconfig
**/talosconfig

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Ignore the _old backup directory
_ref/
